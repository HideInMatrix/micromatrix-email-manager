generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model AppUser {
  email         String        @id
  name          String?
  passwordHash  String?
  role          String        @default("user")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      MailAccount[]
  apiTokens     ApiToken[]    @relation("ApiTokenUser")
  createdTokens ApiToken[]    @relation("ApiTokenCreator")
}

model ApiToken {
  id             String    @id
  name           String    @default("")
  tokenHash      String    @unique
  tokenPrefix    String
  userEmail      String
  createdByEmail String
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           AppUser   @relation("ApiTokenUser", fields: [userEmail], references: [email], onDelete: Cascade)
  createdBy      AppUser   @relation("ApiTokenCreator", fields: [createdByEmail], references: [email], onDelete: Cascade)

  @@index([userEmail])
  @@index([createdByEmail])
  @@index([revokedAt])
}

model MailAccount {
  id               String        @id
  ownerEmail       String?
  provider         String
  email            String
  name             String
  picture          String?
  scopeJson        String        @default("[]")
  tokenCipher      String
  status           String
  providerDataJson String        @default("{}")
  lastSyncAt       DateTime?
  lastError        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  owner            AppUser?      @relation(fields: [ownerEmail], references: [email], onDelete: SetNull)
  messages         MailMessage[]

  @@unique([provider, email])
  @@index([ownerEmail])
  @@index([provider])
  @@index([status])
}

model MailMessage {
  accountId       String
  messageId       String
  provider        String
  threadId        String
  subject         String
  fromAddress     String
  toAddress       String
  date            String
  snippet         String
  labelsJson      String   @default("[]")
  unread          Boolean  @default(false)
  internalDate    BigInt
  bodyText        String?
  bodyHtml        String?
  attachmentsJson String   @default("[]")
  ruleMatchesJson String   @default("[]")
  receivedAt      DateTime
  updatedAt       DateTime @updatedAt
  account         MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([accountId, messageId])
  @@index([provider])
  @@index([unread])
  @@index([internalDate])
}

model AutomationRule {
  id            String    @id
  provider      String    @default("gmail")
  name          String
  enabled       Boolean   @default(true)
  matchJson     String    @default("{}")
  actionJson    String    @default("{}")
  matchCount    Int       @default(0)
  lastMatchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([provider])
}

model OAuthState {
  id        String   @id
  provider  String
  createdAt DateTime @default(now())

  @@index([provider])
  @@index([createdAt])
}

model ProviderConfig {
  provider           String   @id
  clientId           String   @default("")
  clientSecretCipher String   @default("")
  pubsubTopic        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AppEvent {
  id        String   @id
  type      String
  message   String
  accountId String?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([accountId])
  @@index([createdAt])
}
